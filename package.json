{
  "name": "fambrain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "bash scripts/dev-all.sh",
    "dev:web": "pnpm --filter @fambrain/web dev",
    "dev:agents": "pnpm --filter @fambrain/agents dev",
    "dev:agents-worker": "pnpm --filter @fambrain/agents dev:worker",
    "chroma:server": "bash scripts/chroma-server.sh",
    "redis:server": "docker compose up -d redis",
    "build": "pnpm --filter @fambrain/db generate && pnpm --filter @fambrain/web build",
    "start": "pnpm --filter @fambrain/web start",
    "lint": "pnpm --filter @fambrain/web lint",
    "db:generate": "pnpm --filter @fambrain/db generate",
    "db:migrate": "pnpm --filter @fambrain/db migrate",
    "db:studio": "pnpm --filter @fambrain/db studio",
    "db:push": "pnpm --filter @fambrain/db push",
    "rebuild:native": "pnpm rebuild better-sqlite3",
    "doc:migrate-to-user": "node scripts/migrate-doc-to-corpus-user.mjs",
    "doc:migrate-layout": "node scripts/migrate-doc-layout.mjs",
    "index:corpus": "bash scripts/index-corpus.sh",
    "parse:documents": "pnpm --filter @fambrain/agents parse:documents",
    "summarize:document": "pnpm --filter @fambrain/agents summarize:document",
    "experiment:mcp-vault": "pnpm --filter @fambrain/agents experiment:mcp-vault",
    "experiment:recall-compare": "pnpm --filter @fambrain/agents experiment:recall-compare",
    "experiment:vercel-ai": "pnpm --filter @fambrain/agents experiment:vercel-ai",
    "experiment:bind-tools": "pnpm --filter @fambrain/agents experiment:bind-tools",
    "pack:deploy": "bash scripts/pack-deploy.sh",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "pnpm": {
    "overrides": {
      "chromadb": "1.10.3"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}

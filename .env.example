# Environment variables — 统一放在仓库根目录 `.env`

DATABASE_URL="file:./packages/db/prisma/dev.db"

# --- 服务端口（改这里即可；完整 URL 变量可覆盖 HOST+PORT）---
PORT=3000
AGENTS_HOST=127.0.0.1
AGENTS_PORT=3001
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8030

# --- Redis（检索 cache / BullMQ 队列；Docker 内用 redis://redis:6379）---
# 本地 pnpm dev：未设 REDIS_URL 且 REDIS_ENABLED≠1 时自动用进程 memory fallback
# REDIS_ENABLED=1
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_KEY_PREFIX=fambrain
# REDIS_URL="redis://127.0.0.1:6379"
# URL 带 /N 时优先于 REDIS_DB，例如 redis://127.0.0.1:6379/2
# DEV_REDIS_AUTO_START=1  # pnpm dev 时 Redis 不可达则 docker compose up redis（默认 1）

# --- Pipeline cache 开关（=1 关闭；默认均开启）---
# 同问短路：normalize 相同 user 问 → 复用上轮 assistant 答（repeat-question-guard）
# REPEAT_QUESTION_CACHE_DISABLED=0
# 检索结果 cache（corpusUserId + searchQuery + queryType）
# RETRIEVAL_CACHE_DISABLED=0
# RETRIEVAL_CACHE_TTL_MS=900000
# RETRIEVAL_CACHE_MAX_ENTRIES=256
# composite 子问终稿 cache（会话 facet + 增量 composite）
# COMPOSITE_ANSWER_CACHE_DISABLED=0
# COMPOSITE_ANSWER_CACHE_TTL_MS=900000
# COMPOSITE_ANSWER_CACHE_MAX_ENTRIES=128
# keyPrefix 默认 ${REDIS_KEY_PREFIX}:composite-answer

# --- 检索结果 cache（D5-2）· 见上 ---

# --- Pipeline 异步队列（BullMQ；需 Redis + dev:worker）---
# 未设时默认 ${REDIS_KEY_PREFIX}-pipeline / ${REDIS_KEY_PREFIX}:pipeline:events
# PIPELINE_QUEUE_ENABLED=0
# PIPELINE_QUEUE_NAME=fambrain-pipeline
# PIPELINE_QUEUE_CONCURRENCY=2
# PIPELINE_QUEUE_JOB_TTL_MS=3600000
# PIPELINE_QUEUE_EVENT_PREFIX=fambrain:pipeline:events

# 可选：直接写完整 URL（设置后优先于 HOST+PORT）
# AGENTS_SERVICE_URL="http://127.0.0.1:3001"

# 可选：直接写完整 URL（设置后优先于 HOST+PORT）
# 本机 pnpm dev：可指向局域网台式机 Ollama，例如 http://192.168.1.100:11434
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# CHROMA_SERVER_URL="http://127.0.0.1:8030"

# --- 模型 ---
OLLAMA_MODEL="qwen2.5:14b"
# OLLAMA_MODEL_INTAKE_COORDINATOR="qwen2.5:14b"
# OLLAMA_MODEL_EMBED="nomic-embed-text"

# 入库 embed：同时进行的批次数 / 每批 chunk 数（默认 3 / 8）
# INDEX_EMBED_CONCURRENCY=3
# INDEX_EMBED_BATCH_SIZE=8

# 文档解析：批量解析并发数（默认 2）
# DOC_PARSE_CONCURRENCY=2
# 图片 OCR 使用的 Ollama 视觉模型（默认沿用 OLLAMA_MODEL；建议 llava 等 vision 模型）
# OLLAMA_MODEL_VISION="llava"

# Mem0 跨会话记忆 / LangMem 会话摘要（默认开启；需 Ollama）
# MEM0_ENABLED=true
# MEM0_HISTORY_DB_PATH="data/memory/mem0/history.db"
# MEM0_SEARCH_LIMIT=5
# LANGMEM_ENABLED=true
# LANGMEM_SESSIONS_DIR="data/memory/sessions"
# LANGMEM_SUMMARIZE_AFTER_TURNS=8
# LANGMEM_KEEP_RECENT_TURNS=4

# 自主学习管道（Phase A–D；默认开启）
# LEARNING_PIPELINE_ENABLED=true
# LEARNING_AUTO_MEM0_MIN_CONFIDENCE=0.85
# LEARNING_AUTO_CORPUS_MIN_CONFIDENCE=0.92
# LEARNING_PENDING_MIN_CONFIDENCE=0.55
# OLLAMA_STREAM_THINK="true"

# LangSmith 链路追踪（Web UI：https://smith.langchain.com）
# 配置 API Key 后默认开启；设 LANGSMITH_TRACING=false 可关闭
# LANGSMITH_API_KEY="lsv2_pt_..."
# LANGSMITH_PROJECT="fambrain"
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com"

# 离线 parse:documents 默认语料归属（Web 登录用户会自动解析，一般无需配置）
# FAMBRAIN_CORPUS_USER_ID=""
# FAMBRAIN_ACTOR_USER_ID=""

# JWT（生产必填，长度 >= 24）
# JWT_SECRET=""

# 可选：LOGIN_/REGISTER_/LOGOUT_RATE_LIMIT_*、JWT_RENEW_BEFORE_EXPIRY_SEC、
# TRUST_PROXY_HEADERS、SECURITY_ENABLE_HSTS、FAMBRAIN_MEMBERSHIP_AUDIT_ID_SUFFIX

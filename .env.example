# Environment variables — 统一放在仓库根目录 `.env`

DATABASE_URL="file:./packages/db/prisma/dev.db"

# --- 服务端口（改这里即可；完整 URL 变量可覆盖 HOST+PORT）---
PORT=3000
AGENTS_HOST=127.0.0.1
AGENTS_PORT=3001
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8030

# 可选：直接写完整 URL（设置后优先于 HOST+PORT）
# AGENTS_SERVICE_URL="http://127.0.0.1:3001"

# 可选：直接写完整 URL（设置后优先于 HOST+PORT）
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# CHROMA_SERVER_URL="http://127.0.0.1:8030"

# --- 模型 ---
OLLAMA_MODEL="qwen2.5:14b"
# OLLAMA_MODEL_INTAKE_COORDINATOR="qwen2.5:14b"
# OLLAMA_MODEL_EMBED="nomic-embed-text"

# 入库 embed：同时进行的批次数 / 每批 chunk 数（默认 3 / 8）
# INDEX_EMBED_CONCURRENCY=3
# INDEX_EMBED_BATCH_SIZE=8

# Mem0 跨会话记忆 / LangMem 会话摘要（默认开启；需 Ollama）
# MEM0_ENABLED=true
# MEM0_HISTORY_DB_PATH="data/memory/mem0/history.db"
# MEM0_SEARCH_LIMIT=5
# LANGMEM_ENABLED=true
# LANGMEM_SESSIONS_DIR="data/memory/sessions"
# LANGMEM_SUMMARIZE_AFTER_TURNS=8
# LANGMEM_KEEP_RECENT_TURNS=4
# OLLAMA_STREAM_THINK="true"

# FAMBRAIN_CORPUS_USER_ID=""

# JWT（生产必填，长度 >= 24）
# JWT_SECRET=""

# 可选：LOGIN_/REGISTER_/LOGOUT_RATE_LIMIT_*、JWT_RENEW_BEFORE_EXPIRY_SEC、
# TRUST_PROXY_HEADERS、SECURITY_ENABLE_HSTS、FAMBRAIN_MEMBERSHIP_AUDIT_ID_SUFFIX

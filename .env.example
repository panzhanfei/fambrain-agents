DATABASE_URL="file:./prisma/dev.db"

# Ollama：基础地址（可无尾部斜杠），模型列表 GET ${OLLAMA_BASE_URL}/api/tags
OLLAMA_BASE_URL="http://127.0.0.1:11434"
# 默认对话模型；未单独指定时 IntakeCoordinator 也用此模型
OLLAMA_MODEL="qwen2.5:14b"
# 可选：仅入口接线员使用其它模型（不配则等于 OLLAMA_MODEL）
# OLLAMA_MODEL_INTAKE_COORDINATOR="qwen2.5:14b"
# 可选：嵌入模型（RAG）；不配则默认 nomic-embed-text
# OLLAMA_MODEL_EMBED="nomic-embed-text"

# 可选：流式聊天是否向 Ollama 请求 thinking（true/false）；旧版或部分模型不支持时在服务端会自动再试不带 think
# OLLAMA_STREAM_THINK="true"

# 可选：强制所有登录用户检索同一语料目录 src/doc/users/<此 userId>/（一般不必设置，用 User.corpusUserId 即可）
# FAMBRAIN_CORPUS_USER_ID=""

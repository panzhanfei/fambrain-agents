// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// 会话方：用户提问、助手回复、可选系统消息（对齐 OpenAI Chat Completions）
enum ChatRole {
  user
  assistant
  system
}

enum UserRole {
  ADMIN
  MEMBER
}

/// 账号审核状态：管理员同意后才能使用主界面
enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

model User {
  id        String     @id @default(cuid())
  /// 登录名（唯一）
  username  String     @unique
  passwordHash String
  /// 身份证号（全局唯一）
  nationalId String @unique
  /// 在家庭中的展示称呼
  displayName String
  /// 与家庭主账号/本人的关系说明，例如：配偶、父亲、大女儿
  relationToPrincipal String
  /// 个人知识库语料归属用户 id；为空则使用本人 id。家庭成员可指向主角账号。
  corpusUserId String?

  role      UserRole   @default(MEMBER)
  status    UserStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]
  pendingMemoryFacts PendingMemoryFact[]
  retrievalFeedbacks RetrievalFeedback[]
  turnTraces TurnTrace[]
}

enum PendingMemoryFactStatus {
  PENDING
  APPROVED
  REJECTED
  PROMOTED
}

enum MemoryCandidateTarget {
  MEM0
  CORPUS_LEARNED
  BOTH
}

/// 对话抽取的待确认记忆候选（Phase A）
model PendingMemoryFact {
  id                   String                  @id @default(cuid())
  userId               String
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  corpusUserId         String
  factKey              String
  label                String
  value                String
  confidence           Float                   @default(0.5)
  target               MemoryCandidateTarget   @default(MEM0)
  status               PendingMemoryFactStatus @default(PENDING)
  sourceConversationId String?
  sourceUserQuestion   String?
  citations            Json?
  learnedPath          String?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([userId, status])
  @@index([corpusUserId, status])
}

/// 检索路径反馈信号（Phase D）
model RetrievalFeedback {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  corpusUserId   String
  conversationId String?
  messageId      String?
  repoPath       String
  signal         Int
  query          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([corpusUserId, repoPath])
  @@index([userId, messageId])
}

/// 对话会话（侧边列表一条）
model Conversation {
  id        String    @id @default(cuid())
  /// 归属用户（多成员隔离会话）
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 列表标题，可由首条消息或手动更新
  title     String    @default("新对话")
  /// 侧边栏置顶（置顶项排在列表最前）
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
  turnTraces TurnTrace[]

  @@index([userId, pinned, updatedAt])
}

/// 单轮 Pipeline 轨迹（耗时 + step + agent log）；以助手 messageId 为稳定键
model TurnTrace {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// 助手消息 id（历史回放主键）
  messageId      String   @unique
  userMessageId  String?
  userQuestion   String?
  status         String   @default("done")
  timing         Json?
  entries        Json
  steps          Json
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([userId, conversationId])
}

/// 单轮消息（同属一个 Conversation）
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    ChatRole
  /// 纯文本正文；结构化扩展放 metadata（如附件、tokens）
  content String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}
